# Managed by Rover (Ansible). Edits may be overwritten on re-provision.
# Put personal settings (user.name, user.email, credentials, etc.) in
# ~/.gitconfig.local — that file is not touched by Rover. Git silently
# ignores the include if ~/.gitconfig.local does not exist.

[include]
	path = ~/.gitconfig.local

# delta: syntax-highlighted, side-by-side-capable diff/log/show pager.
[core]
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true

[merge]
	conflictStyle = zdiff3
