# Managed by Rover (Ansible). Edits may be overwritten on re-provision.

# Locale from the host system at provision time.
export LANG={{ rover_locale }}
export LC_ALL={{ rover_locale }}

# If the connecting terminal's terminfo entry is missing on this VM (e.g. a
# terminal that ships its own entry, like Ghostty on a fresh ncurses), fall
# back to a widely-available one. Without this, line editing (Backspace,
# arrows, Home/End) misbehaves over SSH. The VM also ships xterm-ghostty.
if [[ -n "$TERM" ]] && ! infocmp "$TERM" &>/dev/null; then
  export TERM_SAVE="$TERM"
  export TERM="xterm-256color"
fi

# Powerlevel10k instant prompt.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# Skip the interactive configuration wizard on first launch.
export POWERLEVEL9K_DISABLE_CONFIGURATION_WIZARD=true

# History.
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt SHARE_HISTORY HIST_IGNORE_DUPS

# Completion.
autoload -Uz compinit && compinit -u

# Path: include user-local bins (dune installs here).
export PATH="$HOME/.local/bin:$PATH"

# mise: activate runtime/tool version management for interactive shells.
if command -v mise &>/dev/null; then
  eval "$(mise activate zsh)"
fi

# Theme.
source "$HOME/.powerlevel10k/powerlevel10k.zsh-theme"
[[ -f ~/.p10k.zsh ]] && source ~/.p10k.zsh

# Editor.
export EDITOR=micro
export VISUAL=micro

# Aliases.
alias mc='micro'
alias bat='batcat'
alias ez='eza'
alias lzd='lazydocker'
alias gti='gitui'
alias ezr='micro ~/.zshrc'
alias rzr='source ~/.zshrc'

alias cl='claude --dangerously-skip-permissions'
alias cx='codex --dangerously-bypass-approvals-and-sandbox'

# codex: wraps the real binary to inject the Linear MCP bearer token from a
# root-owned key file, read via a narrowly scoped passwordless sudo rule
# (/etc/sudoers.d/codex-linear-key) instead of a file in the home directory.
codex() {
  LINEAR_API_KEY="$(sudo cat /etc/codex/linear.key 2>/dev/null)" command codex "$@"
}

# zoxide: `cd` is backed by the frequency database (matches host setup).
if command -v zoxide &>/dev/null; then
  eval "$(zoxide init --cmd cd zsh)"
fi

# broot: `br` launches broot and cds into the chosen directory.
if [[ -r "$HOME/.config/broot/br.sh" ]]; then
  source "$HOME/.config/broot/br.sh"
fi

# Personal customizations that should survive re-provisioning go in
# ~/.zshrc.local (same convention as .gitconfig.local). Rover never writes
# this file.
[[ -f "$HOME/.zshrc.local" ]] && source "$HOME/.zshrc.local"
