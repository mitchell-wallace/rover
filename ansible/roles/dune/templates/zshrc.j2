# Managed by Rover (Ansible). Edits may be overwritten on re-provision.

# Locale from the host system at provision time.
export LANG={{ rover_locale }}
export LC_ALL={{ rover_locale }}

# If the connecting terminal's terminfo entry is missing on this VM (e.g. a
# terminal that ships its own entry, like Ghostty on a fresh ncurses), fall
# back to a widely-available one. Without this, line editing (Backspace,
# arrows, Home/End) misbehaves over SSH. The VM also ships xterm-ghostty.
if [[ -n "$TERM" ]] && ! infocmp "$TERM" &>/dev/null; then
  export TERM_SAVE="$TERM"
  export TERM="xterm-256color"
fi

# Powerlevel10k instant prompt.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# Skip the interactive configuration wizard on first launch.
export POWERLEVEL9K_DISABLE_CONFIGURATION_WIZARD=true

# History.
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt SHARE_HISTORY HIST_IGNORE_DUPS

# Completion.
autoload -Uz compinit && compinit -u

# Path: include user-local bins (dune installs here).
export PATH="$HOME/.local/bin:$PATH"

# Theme.
source "$HOME/.powerlevel10k/powerlevel10k.zsh-theme"
[[ -f ~/.p10k.zsh ]] && source ~/.p10k.zsh

# Editor.
export EDITOR=micro
export VISUAL=micro

# Aliases.
alias mc='micro'
alias bat='batcat'
alias ez='eza'
alias lzd='lazydocker'
alias gti='gitui'
alias ezr='micro ~/.zshrc'
alias rzr='source ~/.zshrc'

# zoxide: `cd` is backed by the frequency database (matches host setup).
if command -v zoxide &>/dev/null; then
  eval "$(zoxide init --cmd cd zsh)"
fi

# broot: `br` launches broot and cds into the chosen directory.
if [[ -r "$HOME/.config/broot/br.sh" ]]; then
  source "$HOME/.config/broot/br.sh"
fi
